# Supabase
# Diese Werte werden automatisch von Vercel/Supabase Integration gesetzt
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: Supabase Service Role (nur serverseitig, NIE im Client!)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# GitHub
# Personal Access Token für GitHub API (Issues, PRs, etc.)
GITHUB_TOKEN=ghp_your-token-here
